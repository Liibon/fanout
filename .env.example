# fanout / HDSearch - environment variable reference
# Copy to .env and uncomment lines to override defaults.

# Topology
# FAN_OUT=16            # number of leaf shards
# TOP_K=10              # k-nearest neighbours to return
# DIM=128               # vector dimension (must match dataset)
# NUM_VECTORS=1000000   # total vectors across all shards

# Root RPC tuning
# PER_LEAF_TIMEOUT_MS=100
# HEDGING=false
# HEDGING_DELAY_MS=20
# RETRY=false
# MAX_RETRIES=1
# NUM_CANDIDATES=0   # 0 = full-shard FAISS search; >0 = root sends this many candidate IDs
#                    # per leaf and the leaf scores only those (MicroSuite PercentDataSent knob)

# Load generator
# QPS=100
# WARMUP=500
# MEASURE=5000

# Synthetic leaf mode (skip FAISS, sleep instead)
# SYNTHETIC=false
# SYNTHETIC_MU=2.5          # lognormal mean (ms, log-scale)
# SYNTHETIC_SIGMA=0.6       # lognormal std (log-scale)
# SYNTHETIC_HEAVY_PCT=0.01  # fraction of stragglers
# SYNTHETIC_HEAVY_MU=5.0
# SYNTHETIC_HEAVY_SIGMA=0.3
